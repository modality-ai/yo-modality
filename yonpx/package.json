{
  "version": "0.19.0",
  "name": "yonpx",
  "repository": {
    "type": "git",
    "url": "https://github.com/modality-ai/yo-modality",
    "directory": "yonpx"
  },
  "homepage": "https://github.com/modality-ai/yo-modality/tree/main/yonpx",
  "description": "Npx CLI for yeoman",
  "keywords": [
    "create-react-app",
    "create-yo",
    "npx",
    "npm",
    "yo",
    "yeoman",
    "yonpx",
    "yo-npx",
    "npx-yo"
  ],
  "author": "Hill <hill@kimo.com>",
  "license": "ISC",
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2"
  },
  "bin": {
    "yonpx": "./dist/index.mjs"
  },
  "exports": {
    "types": "./dist/types/index.d.ts",
    "import": "./dist/index.mjs"
  },
  "types": "./dist/types/index.d.ts",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "scripts": {
    "build:clean": "find ./dist -name '*.*' | xargs rm -rf",
    "build:src": "bun build src/index.ts --outfile dist/index.mjs --target node",
    "build:types": "bun tsc -p ./",
    "build": "npm run build:clean && npm run build:src && npm run build:types",
    "test": "npm run build && bun test --timeout 5000 ./src/__tests__/",
    "prepublishOnly": "npm t"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "engines": {
    "node": ">=14"
  }
}
